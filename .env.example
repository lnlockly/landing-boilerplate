# Public site URL (used by sitemap + OG tags). Platform injects PREVIEW_URL at build time.
SITE_URL=https://example.com

# Contact form endpoint (when config.cta.action == 'email')
# Coder wires this to telegram-mcp / email service later.
VITE_CONTACT_ENDPOINT=/api/contact

# Telegram bot username (when config.cta.action == 'telegram')
VITE_TELEGRAM_BOT=__BOT__
